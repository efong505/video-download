{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket", 
        "s3:GetObject"
    ],
      "Resource": [
        "arn:aws:s3:::news-scraper-ekewaka/*"
    ]
    },
    {
        "Effect": "Allow",
        "Action": [
            "dynamodb:PutItem",
            "dynamodb:UpdateItem",
            "dynamodb:GetItem",
            "dynamodb:Scan",
            "dynamodb:Query"
        ],
        "Resource": "arn:aws:dynamodb:us-east-1:371751795928:table/NewsArticles"
    },
    {
        "Effect":"Allow",
        "Action": [
            "logs:CreateLogGroup",
            "logs:CreateLogStream",
            "logs:PutLogEvents"
        ],
        "Resource":"arn:aws:logs:us-east-1:371751795928:log-group:NewsScraperLambda:*"
    }
  ]
}
